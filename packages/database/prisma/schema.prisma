generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & PROFILES
// ============================================================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  role          UserRole
  emailVerified Boolean   @default(false) @map("email_verified")
  avatarUrl     String?   @map("avatar_url")
  bannerUrl     String?   @map("banner_url")
  isActive      Boolean   @default(true) @map("is_active")
  isSuspended   Boolean   @default(false) @map("is_suspended")
  reputationScore Int     @default(0) @map("reputation_score")
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  studentProfile  StudentProfile?
  employerProfile EmployerProfile?
  wallet          Wallet?

  sentMessages    Message[]      @relation("MessageSender")
  notifications   Notification[]
  reviewsGiven    Review[]       @relation("ReviewsGiven")
  reviewsReceived Review[]       @relation("ReviewsReceived")
  reports         Report[]       @relation("ReportsBy")
  disputesRaised  Dispute[]      @relation("DisputesRaised")
  disputesResolved Dispute[]     @relation("DisputesResolved")
  endedContracts  Contract[]     @relation("ContractEndedBy")
  auditLogs       AuditLog[]     @relation("AuditLogs")

  // Payments
  transferRecipients TransferRecipient[]
  paymentAuthorizations PaymentAuthorization[]

  // Community
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityLikes    CommunityLike[]

  // Blocked users
  blocking   BlockedUser[] @relation("Blocking")
  blockedBy  BlockedUser[] @relation("BlockedBy")

  // Follow system
  following  UserFollow[] @relation("Following")
  followers  UserFollow[] @relation("Followers")

  // Saved posts
  savedPosts SavedPost[]

  // Post views
  postViews CommunityPostView[]

  @@map("users")
}

model StudentProfile {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  firstName        String   @map("first_name") @db.VarChar(100)
  lastName         String   @map("last_name") @db.VarChar(100)
  professionalTitle String? @map("professional_title") @db.VarChar(200)
  phone            String?  @db.VarChar(20)
  bio              String?
  university       String   @db.VarChar(255)
  major            String?  @db.VarChar(255)
  graduationYear   Int?     @map("graduation_year")
  studentIdNumber  String?  @map("student_id_number") @db.VarChar(50)
  isVerified       Boolean  @default(false) @map("is_verified")
  skills           String[] @default([])
  hourlyRate       Decimal? @map("hourly_rate") @db.Decimal(10, 2)
  portfolioUrls    String[] @default([]) @map("portfolio_urls")
  availability     Json     @default("{}")
  locationLat      Decimal? @map("location_lat") @db.Decimal(10, 8)
  locationLng      Decimal? @map("location_lng") @db.Decimal(11, 8)
  ratingAvg        Decimal  @default(0.00) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount      Int      @default(0) @map("rating_count")
  jobSuccessScore  Int      @default(0) @map("job_success_score")
  talentBadge      TalentBadge @default(none) @map("talent_badge")
  totalEarned      Decimal  @default(0.00) @map("total_earned") @db.Decimal(12, 2)
  gigsCompleted    Int      @default(0) @map("gigs_completed")
  responseTimeHrs  Decimal? @map("response_time_hrs") @db.Decimal(5, 1)
  onTimeRate       Decimal  @default(100.00) @map("on_time_rate") @db.Decimal(5, 2)
  rehireRate       Decimal  @default(0.00) @map("rehire_rate") @db.Decimal(5, 2)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposals         Proposal[]
  contracts         Contract[]         @relation("ContractStudent")
  timeEntries       TimeEntry[]
  connectBalance    ConnectBalance?
  connectTransactions ConnectTransaction[]
  connectPurchases  ConnectPurchase[]
  serviceListings   ServiceListing[]
  serviceOrders     ServiceOrder[]     @relation("ServiceOrderStudent")
  specializedProfiles SpecializedProfile[]
  portfolioItems    PortfolioItem[]
  clientRelationships ClientRelationship[] @relation("StudentRelationships")
  savedGigs         SavedGig[]
  savedByEmployers  SavedTalent[]

  @@map("student_profiles")
}

model EmployerProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  businessName    String   @map("business_name") @db.VarChar(255)
  businessType    String?  @map("business_type") @db.VarChar(50)
  description     String?
  website         String?  @db.VarChar(500)
  logoUrl         String?  @map("logo_url")
  phone           String?  @db.VarChar(20)
  contactPerson   String?  @map("contact_person") @db.VarChar(200)
  isVerified      Boolean  @default(false) @map("is_verified")
  paymentVerified Boolean  @default(false) @map("payment_verified")
  locationAddress String?  @map("location_address")
  locationLat     Decimal? @map("location_lat") @db.Decimal(10, 8)
  locationLng     Decimal? @map("location_lng") @db.Decimal(11, 8)
  ratingAvg       Decimal  @default(0.00) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount     Int      @default(0) @map("rating_count")
  totalSpent      Decimal  @default(0.00) @map("total_spent") @db.Decimal(12, 2)
  gigsPosted      Int      @default(0) @map("gigs_posted")
  hireRate        Decimal  @default(0.00) @map("hire_rate") @db.Decimal(5, 2)
  avgHourlyRate   Decimal? @map("avg_hourly_rate") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  gigs              Gig[]
  contracts         Contract[]         @relation("ContractEmployer")
  serviceOrders     ServiceOrder[]     @relation("ServiceOrderEmployer")
  clientRelationships ClientRelationship[] @relation("EmployerRelationships")
  savedTalent       SavedTalent[]

  @@map("employer_profiles")
}

// ============================================================
// PAYMENT AUTHORIZATIONS (Saved Cards for Recurring Charges)
// ============================================================

model PaymentAuthorization {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  authorizationCode  String   @map("authorization_code") @db.VarChar(255)
  cardType           String?  @map("card_type") @db.VarChar(50)
  last4              String?  @db.VarChar(4)
  expMonth           String?  @map("exp_month") @db.VarChar(2)
  expYear            String?  @map("exp_year") @db.VarChar(4)
  bank               String?  @db.VarChar(100)
  channel            String?  @db.VarChar(50)
  isActive           Boolean  @default(true) @map("is_active")
  isDefault          Boolean  @default(false) @map("is_default")
  paystackEmail      String?  @map("paystack_email") @db.VarChar(255)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("payment_authorizations")
}

// ============================================================
// GIGS & CATEGORIES
// ============================================================

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique @db.VarChar(100)
  slug        String  @unique @db.VarChar(100)
  icon        String? @db.VarChar(50)
  description String?
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  gigs            Gig[]
  serviceListings ServiceListing[]
  portfolioItems  PortfolioItem[]

  @@map("categories")
}

model Gig {
  id                  String       @id @default(uuid()) @db.Uuid
  employerId          String       @map("employer_id") @db.Uuid
  title               String       @db.VarChar(255)
  description         String
  categoryId          String?      @map("category_id") @db.Uuid
  requiredSkills      String[]     @default([]) @map("required_skills")
  budgetType          BudgetType   @map("budget_type")
  budgetMin           Decimal?     @map("budget_min") @db.Decimal(10, 2)
  budgetMax           Decimal?     @map("budget_max") @db.Decimal(10, 2)
  currency            String       @default("GHS") @db.VarChar(3)
  locationType        LocationType @map("location_type")
  locationAddress     String?      @map("location_address")
  locationLat         Decimal?     @map("location_lat") @db.Decimal(10, 8)
  locationLng         Decimal?     @map("location_lng") @db.Decimal(11, 8)
  experienceLevel     ExperienceLevel @default(entry) @map("experience_level")
  projectScope        ProjectScope @default(small) @map("project_scope")
  urgency             Urgency      @default(flexible)
  durationHours       Int?         @map("duration_hours")
  deadline            DateTime?    @db.Timestamptz
  maxProposals        Int          @default(50) @map("max_proposals")
  visibility          GigVisibility @default(public)
  screeningQuestions  Json         @default("[]") @map("screening_questions")
  preferredQuals      Json         @default("{}") @map("preferred_quals")
  connectsRequired    Int          @default(2) @map("connects_required")
  status              GigStatus    @default(draft)
  attachments         Json         @default("[]")
  viewsCount          Int          @default(0) @map("views_count")
  proposalsCount      Int          @default(0) @map("proposals_count")
  publishedAt         DateTime?    @map("published_at") @db.Timestamptz
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  employer        EmployerProfile @relation(fields: [employerId], references: [id])
  category        Category?       @relation(fields: [categoryId], references: [id])
  proposals       Proposal[]
  contracts       Contract[]
  conversations   Conversation[]
  savedBy         SavedGig[]
  communityPosts  CommunityPost[]

  @@index([status])
  @@index([categoryId])
  @@index([employerId])
  @@index([publishedAt(sort: Desc)])
  @@map("gigs")
}

// ============================================================
// PROPOSALS
// ============================================================

model Proposal {
  id                 String         @id @default(uuid()) @db.Uuid
  gigId              String         @map("gig_id") @db.Uuid
  studentId          String         @map("student_id") @db.Uuid
  coverLetter        String         @map("cover_letter")
  proposedRate       Decimal        @map("proposed_rate") @db.Decimal(10, 2)
  estimatedDuration  String?        @map("estimated_duration") @db.VarChar(100)
  proposedMilestones Json           @default("[]") @map("proposed_milestones")
  screeningAnswers   Json           @default("[]") @map("screening_answers")
  connectsSpent      Int            @default(2) @map("connects_spent")
  isBoosted          Boolean        @default(false) @map("is_boosted")
  boostConnects      Int            @default(0) @map("boost_connects")
  status             ProposalStatus @default(submitted)
  employerNotes      String?        @map("employer_notes")
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  gig      Gig            @relation(fields: [gigId], references: [id])
  student  StudentProfile @relation(fields: [studentId], references: [id])
  contract Contract?

  @@unique([gigId, studentId])
  @@index([gigId, status])
  @@index([studentId, status])
  @@map("proposals")
}

// ============================================================
// CONTRACTS & MILESTONES
// ============================================================

model Contract {
  id                String         @id @default(uuid()) @db.Uuid
  gigId             String?        @map("gig_id") @db.Uuid
  proposalId        String?        @unique @map("proposal_id") @db.Uuid
  studentId         String         @map("student_id") @db.Uuid
  employerId        String         @map("employer_id") @db.Uuid
  contractType      ContractType   @map("contract_type")
  title             String         @db.VarChar(255)
  description       String?
  agreedRate        Decimal        @map("agreed_rate") @db.Decimal(10, 2)
  currency          String         @default("GHS") @db.VarChar(3)
  weeklyLimit       Int?           @map("weekly_limit")
  feeTierSnapshot   Json           @default("{}") @map("fee_tier_snapshot")
  status            ContractStatus @default(active)
  isDirect          Boolean        @default(false) @map("is_direct")
  startedAt         DateTime       @default(now()) @map("started_at") @db.Timestamptz
  pausedAt          DateTime?      @map("paused_at") @db.Timestamptz
  completedAt       DateTime?      @map("completed_at") @db.Timestamptz
  endedById         String?        @map("ended_by") @db.Uuid
  endReason         String?        @map("end_reason")
  lifetimeBillings  Decimal        @default(0.00) @map("lifetime_billings") @db.Decimal(12, 2)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  gig            Gig?            @relation(fields: [gigId], references: [id])
  proposal       Proposal?       @relation(fields: [proposalId], references: [id])
  student        StudentProfile  @relation("ContractStudent", fields: [studentId], references: [id])
  employer       EmployerProfile @relation("ContractEmployer", fields: [employerId], references: [id])
  endedBy        User?           @relation("ContractEndedBy", fields: [endedById], references: [id])
  milestones     Milestone[]
  timeEntries    TimeEntry[]
  weeklyInvoices WeeklyInvoice[]
  payments       Payment[]
  reviews        Review[]
  disputes       Dispute[]
  escrowTransactions EscrowTransaction[]

  @@index([studentId, status])
  @@index([employerId, status])
  @@map("contracts")
}

model Milestone {
  id                String          @id @default(uuid()) @db.Uuid
  contractId        String          @map("contract_id") @db.Uuid
  title             String          @db.VarChar(255)
  description       String?
  amount            Decimal         @db.Decimal(10, 2)
  dueDate           DateTime?       @map("due_date") @db.Timestamptz
  sortOrder         Int             @default(0) @map("sort_order")
  status            MilestoneStatus @default(pending)
  deliverables      Json            @default("[]")
  revisionCount     Int             @default(0) @map("revision_count")
  maxRevisions      Int             @default(2) @map("max_revisions")
  submittedAt       DateTime?       @map("submitted_at") @db.Timestamptz
  approvedAt        DateTime?       @map("approved_at") @db.Timestamptz
  paidAt            DateTime?       @map("paid_at") @db.Timestamptz
  autoApproveAt     DateTime?       @map("auto_approve_at") @db.Timestamptz
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  contract Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  payments Payment[]
  escrowTransactions EscrowTransaction[]
  disputes Dispute[]

  @@index([contractId, sortOrder])
  @@map("milestones")
}

// ============================================================
// HOURLY TIME TRACKING
// ============================================================

model TimeEntry {
  id          String   @id @default(uuid()) @db.Uuid
  contractId  String   @map("contract_id") @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  description String
  hours       Decimal  @db.Decimal(5, 2)
  dateWorked  DateTime @map("date_worked") @db.Date
  billingWeek DateTime @map("billing_week") @db.Date
  isBilled    Boolean  @default(false) @map("is_billed")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contract Contract       @relation(fields: [contractId], references: [id])
  student  StudentProfile @relation(fields: [studentId], references: [id])

  @@index([contractId, billingWeek])
  @@map("time_entries")
}

model WeeklyInvoice {
  id          String              @id @default(uuid()) @db.Uuid
  contractId  String              @map("contract_id") @db.Uuid
  billingWeek DateTime            @map("billing_week") @db.Date
  totalHours  Decimal             @map("total_hours") @db.Decimal(5, 2)
  hourlyRate  Decimal             @map("hourly_rate") @db.Decimal(10, 2)
  subtotal    Decimal             @db.Decimal(10, 2)
  platformFee Decimal             @map("platform_fee") @db.Decimal(10, 2)
  status      WeeklyInvoiceStatus @default(pending)
  paidAt      DateTime?           @map("paid_at") @db.Timestamptz
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz

  contract Contract  @relation(fields: [contractId], references: [id])
  payments Payment[]

  @@unique([contractId, billingWeek])
  @@map("weekly_invoices")
}

// ============================================================
// CONNECTS SYSTEM
// ============================================================

model ConnectBalance {
  id                String   @id @default(uuid()) @db.Uuid
  studentId         String   @unique @map("student_id") @db.Uuid
  freeConnects      Int      @default(15) @map("free_connects")
  purchasedConnects Int      @default(0) @map("purchased_connects")
  rolloverConnects  Int      @default(0) @map("rollover_connects")
  lastRefreshAt     DateTime @default(now()) @map("last_refresh_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("connect_balances")
}

model ConnectTransaction {
  id          String                @id @default(uuid()) @db.Uuid
  studentId   String                @map("student_id") @db.Uuid
  type        ConnectTransactionType
  amount      Int
  balanceAfter Int                  @map("balance_after")
  referenceId String?               @map("reference_id") @db.Uuid
  description String?
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt(sort: Desc)])
  @@map("connect_transactions")
}

model ConnectPurchase {
  id               String                @id @default(uuid()) @db.Uuid
  studentId        String                @map("student_id") @db.Uuid
  packSize         Int                   @map("pack_size")
  price            Decimal               @db.Decimal(10, 2)
  paymentReference String?               @map("payment_reference") @db.VarChar(255)
  status           ConnectPurchaseStatus @default(pending)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("connect_purchases")
}

// ============================================================
// STUDENT SERVICE CATALOG
// ============================================================

model ServiceListing {
  id           String               @id @default(uuid()) @db.Uuid
  studentId    String               @map("student_id") @db.Uuid
  title        String               @db.VarChar(255)
  description  String
  categoryId   String?              @map("category_id") @db.Uuid
  tags         String[]             @default([])
  deliveryDays Int                  @map("delivery_days")
  tiers        Json                 @default("[]")
  images       Json                 @default("[]")
  faq          Json                 @default("[]")
  status       ServiceListingStatus @default(draft)
  isFeatured   Boolean              @default(false) @map("is_featured")
  ordersCount  Int                  @default(0) @map("orders_count")
  ratingAvg    Decimal              @default(0.00) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount  Int                  @default(0) @map("rating_count")
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  student  StudentProfile @relation(fields: [studentId], references: [id])
  category Category?      @relation(fields: [categoryId], references: [id])
  orders   ServiceOrder[]

  @@index([studentId])
  @@index([categoryId])
  @@map("service_listings")
}

// ============================================================
// PORTFOLIO SHOWCASE
// ============================================================

model PortfolioItem {
  id             String              @id @default(uuid()) @db.Uuid
  studentId      String              @map("student_id") @db.Uuid
  title          String              @db.VarChar(255)
  description    String
  categoryId     String?             @map("category_id") @db.Uuid
  skills         String[]            @default([])
  images         String[]            @default([])
  projectUrl     String?             @map("project_url") @db.VarChar(500)
  clientName     String?             @map("client_name") @db.VarChar(200)
  completedAt    DateTime?           @map("completed_at") @db.Timestamptz
  status         PortfolioStatus     @default(published)
  isFeatured     Boolean             @default(false) @map("is_featured")
  likeCount      Int                 @default(0) @map("like_count")
  viewCount      Int                 @default(0) @map("view_count")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  student  StudentProfile @relation(fields: [studentId], references: [id])
  category Category?      @relation(fields: [categoryId], references: [id])

  @@index([studentId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("portfolio_items")
}

enum PortfolioStatus {
  draft
  published
  archived
}

model ServiceOrder {
  id               String             @id @default(uuid()) @db.Uuid
  serviceListingId String             @map("service_listing_id") @db.Uuid
  employerId       String             @map("employer_id") @db.Uuid
  studentId        String             @map("student_id") @db.Uuid
  tierSelected     String             @map("tier_selected") @db.VarChar(50)
  amount           Decimal            @db.Decimal(10, 2)
  requirements     String?
  status           ServiceOrderStatus @default(pending)
  deliveryDeadline DateTime?          @map("delivery_deadline") @db.Timestamptz
  deliverables     Json               @default("[]")
  revisionCount    Int                @default(0) @map("revision_count")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  serviceListing ServiceListing  @relation(fields: [serviceListingId], references: [id])
  employer       EmployerProfile @relation("ServiceOrderEmployer", fields: [employerId], references: [id])
  student        StudentProfile  @relation("ServiceOrderStudent", fields: [studentId], references: [id])
  payments       Payment[]
  escrowTransactions EscrowTransaction[]
  disputes       Dispute[]

  @@map("service_orders")
}

// ============================================================
// SPECIALIZED PROFILES
// ============================================================

model SpecializedProfile {
  id           String   @id @default(uuid()) @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  title        String   @db.VarChar(200)
  overview     String?
  skills       String[] @default([])
  hourlyRate   Decimal? @map("hourly_rate") @db.Decimal(10, 2)
  portfolioUrls String[] @default([]) @map("portfolio_urls")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student StudentProfile @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@map("specialized_profiles")
}

// ============================================================
// CLIENT RELATIONSHIP TRACKING (sliding fee)
// ============================================================

model ClientRelationship {
  id               String   @id @default(uuid()) @db.Uuid
  studentId        String   @map("student_id") @db.Uuid
  employerId       String   @map("employer_id") @db.Uuid
  lifetimeBillings Decimal  @default(0.00) @map("lifetime_billings") @db.Decimal(12, 2)
  currentFeeTier   FeeTier  @default(tier_1) @map("current_fee_tier")
  contractsCount   Int      @default(0) @map("contracts_count")
  firstContractAt  DateTime? @map("first_contract_at") @db.Timestamptz
  lastContractAt   DateTime? @map("last_contract_at") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  student  StudentProfile  @relation("StudentRelationships", fields: [studentId], references: [id])
  employer EmployerProfile @relation("EmployerRelationships", fields: [employerId], references: [id])

  @@unique([studentId, employerId])
  @@map("client_relationships")
}

// ============================================================
// PAYMENTS & WALLET
// ============================================================

model Wallet {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @unique @map("user_id") @db.Uuid
  balance                Decimal  @default(0.00) @db.Decimal(12, 2)
  pendingBalance         Decimal  @default(0.00) @map("pending_balance") @db.Decimal(12, 2)
  currency               String   @default("GHS") @db.VarChar(3)
  autoWithdrawEnabled    Boolean  @default(false) @map("auto_withdraw_enabled")
  autoWithdrawThreshold  Decimal? @map("auto_withdraw_threshold") @db.Decimal(10, 2)
  dailyWithdrawalLimit   Decimal  @default(10000) @map("daily_withdrawal_limit") @db.Decimal(10, 2)
  dailyWithdrawnToday    Decimal  @default(0) @map("daily_withdrawn_today") @db.Decimal(10, 2)
  dailyWithdrawalResetAt DateTime @default(now()) @map("daily_withdrawal_reset_at") @db.Timestamptz
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
  withdrawals  Withdrawal[]

  @@map("wallets")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  contractId      String?       @map("contract_id") @db.Uuid
  milestoneId     String?       @map("milestone_id") @db.Uuid
  weeklyInvoiceId String?       @map("weekly_invoice_id") @db.Uuid
  serviceOrderId  String?       @map("service_order_id") @db.Uuid
  payerId         String        @map("payer_id") @db.Uuid
  payeeId         String        @map("payee_id") @db.Uuid
  amount          Decimal       @db.Decimal(10, 2)
  platformFee     Decimal       @map("platform_fee") @db.Decimal(10, 2)
  feePercentage   Decimal       @map("fee_percentage") @db.Decimal(5, 2)
  netAmount       Decimal       @map("net_amount") @db.Decimal(10, 2)
  currency        String        @default("GHS") @db.VarChar(3)
  type            PaymentType
  status          PaymentStatus @default(pending)
  paymentMethod   String?       @map("payment_method") @db.VarChar(50)
  externalTxnId   String?       @map("external_txn_id") @db.VarChar(255)
  escrowAt        DateTime?     @map("escrow_at") @db.Timestamptz
  releasedAt      DateTime?     @map("released_at") @db.Timestamptz
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  contract     Contract?     @relation(fields: [contractId], references: [id])
  milestone    Milestone?    @relation(fields: [milestoneId], references: [id])
  weeklyInvoice WeeklyInvoice? @relation(fields: [weeklyInvoiceId], references: [id])
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  transactions Transaction[]

  @@index([payerId, status])
  @@index([payeeId, status])
  @@index([contractId])
  @@index([status])
  @@map("payments")
}

model Transaction {
  id           String          @id @default(uuid()) @db.Uuid
  walletId     String          @map("wallet_id") @db.Uuid
  paymentId    String?         @map("payment_id") @db.Uuid
  type         TransactionType
  amount       Decimal         @db.Decimal(10, 2)
  balanceAfter Decimal         @map("balance_after") @db.Decimal(12, 2)
  description  String?
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz

  wallet  Wallet   @relation(fields: [walletId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([walletId, createdAt(sort: Desc)])
  @@map("transactions")
}

model Withdrawal {
  id            String           @id @default(uuid()) @db.Uuid
  walletId      String           @map("wallet_id") @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  amount        Decimal          @db.Decimal(10, 2)
  destination   Json
  reference     String?          @unique @db.VarChar(100)
  status        WithdrawalStatus @default(pending)
  externalTxnId String?          @map("external_txn_id") @db.VarChar(255)
  failureReason String?          @map("failure_reason")
  retryCount    Int              @default(0) @map("retry_count")
  lastRetryAt   DateTime?        @map("last_retry_at") @db.Timestamptz
  processedAt   DateTime?        @map("processed_at") @db.Timestamptz
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, status])
  @@index([userId])
  @@index([status, retryCount])
  @@map("withdrawals")
}

// ============================================================
// ESCROW SYSTEM
// ============================================================

model EscrowTransaction {
  id                 String              @id @default(uuid()) @db.Uuid
  milestoneId        String?             @map("milestone_id") @db.Uuid
  serviceOrderId     String?             @map("service_order_id") @db.Uuid
  contractId         String              @map("contract_id") @db.Uuid
  payerId            String              @map("payer_id") @db.Uuid
  payeeId            String              @map("payee_id") @db.Uuid
  amount             Decimal             @db.Decimal(10, 2)
  currency           String              @default("GHS") @db.VarChar(3)
  status             EscrowStatus        @default(pending)
  paystackReference  String?             @unique @map("paystack_reference") @db.VarChar(255)
  paystackTransferId String?             @map("paystack_transfer_id") @db.VarChar(255)
  platformFee        Decimal             @default(0) @map("platform_fee") @db.Decimal(10, 2)
  feePercentage      Decimal             @default(0) @map("fee_percentage") @db.Decimal(5, 2)
  netAmount          Decimal             @default(0) @map("net_amount") @db.Decimal(10, 2)
  fundedAt           DateTime?           @map("funded_at") @db.Timestamptz
  releasedAt         DateTime?           @map("released_at") @db.Timestamptz
  refundedAt         DateTime?           @map("refunded_at") @db.Timestamptz
  failedAt           DateTime?           @map("failed_at") @db.Timestamptz
  failureReason      String?             @map("failure_reason")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  contract     Contract      @relation(fields: [contractId], references: [id])
  milestone    Milestone?    @relation(fields: [milestoneId], references: [id])
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id])

  @@index([contractId])
  @@index([milestoneId])
  @@index([serviceOrderId])
  @@index([payerId])
  @@index([payeeId])
  @@index([status])
