model WebhookEvent {
  id                String    @id @default(uuid()) @db.Uuid
  paystackReference String    @unique @map("paystack_reference") @db.VarChar(255)
  eventType         String    @map("event_type") @db.VarChar(100)
  payload           Json
  receivedAt        DateTime  @default(now()) @map("received_at") @db.Timestamptz
  processedAt       DateTime? @map("processed_at") @db.Timestamptz

  @@index([eventType])
  @@index([processedAt])
  @@map("webhook_events")
}

model TransferRecipient {
  id                  String                  @id @default(uuid()) @db.Uuid
  userId              String                  @map("user_id") @db.Uuid
  type                TransferRecipientType
  recipientCode       String                  @unique @map("recipient_code") @db.VarChar(255)
  accountName         String                  @map("account_name") @db.VarChar(255)
  accountNumber       String                  @map("account_number") @db.VarChar(50)
  bankCode            String                  @map("bank_code") @db.VarChar(50)
  bankName            String?                 @map("bank_name") @db.VarChar(255)
  currency            String                  @default("GHS") @db.VarChar(3)
  isDefault           Boolean                 @default(false) @map("is_default")
  isActive            Boolean                 @default(true) @map("is_active")
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("transfer_recipients")
}

model FinancialAuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  action          String   @db.VarChar(100)
  entityType      String   @map("entity_type") @db.VarChar(50)
  entityId        String?  @map("entity_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  amount          Decimal? @db.Decimal(10, 2)
  balanceBefore   Decimal? @map("balance_before") @db.Decimal(12, 2)
  balanceAfter    Decimal? @map("balance_after") @db.Decimal(12, 2)
  currency        String   @default("GHS") @db.VarChar(3)
  paystackRef     String?  @map("paystack_ref") @db.VarChar(255)
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("financial_audit_log")
}

// ============================================================
// RECONCILIATION
// ============================================================

model ReconciliationRun {
  id                        String               @id @default(uuid()) @db.Uuid
  runDate                   DateTime             @map("run_date") @db.Date
  runType                   String               @map("run_type") @db.VarChar(50) // daily, weekly, manual

  // Our ledger totals
  totalEscrowHeld           Decimal              @map("total_escrow_held") @db.Decimal(14, 2)
  totalStudentWallets       Decimal              @map("total_student_wallets") @db.Decimal(14, 2)
  totalPendingWithdrawals   Decimal              @map("total_pending_withdrawals") @db.Decimal(14, 2)
  totalPlatformRevenue      Decimal              @map("total_platform_revenue") @db.Decimal(14, 2)
  calculatedPaystackBalance Decimal              @map("calculated_paystack_balance") @db.Decimal(14, 2)

  // Actual Paystack balance
  actualPaystackBalance     Decimal?             @map("actual_paystack_balance") @db.Decimal(14, 2)

  // Discrepancy
  discrepancy               Decimal?             @db.Decimal(14, 2)
  discrepancyPercentage     Decimal?             @map("discrepancy_percentage") @db.Decimal(7, 4)

  isBalanced                Boolean              @map("is_balanced")
  orphanedTransactions      Int                  @default(0) @map("orphaned_transactions")
  stuckTransfers            Int                  @default(0) @map("stuck_transfers")
  notes                     String?
  resolvedAt                DateTime?            @map("resolved_at") @db.Timestamptz
  createdAt                 DateTime             @default(now()) @map("created_at") @db.Timestamptz

  @@index([runDate])
  @@index([isBalanced])
  @@map("reconciliation_runs")
}

// ============================================================
// MESSAGING
// ============================================================

model Conversation {
  id             String    @id @default(uuid()) @db.Uuid
  gigId          String?   @map("gig_id") @db.Uuid
  participantIds String[]  @map("participant_ids") @db.Uuid
  lastMessageAt  DateTime? @map("last_message_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  gig      Gig?      @relation(fields: [gigId], references: [id])
  messages Message[]

  @@index([gigId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  content        String
  attachments    Json     @default("[]")
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

// ============================================================
// REVIEWS
// ============================================================

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  contractId String   @map("contract_id") @db.Uuid
  reviewerId String   @map("reviewer_id") @db.Uuid
  revieweeId String   @map("reviewee_id") @db.Uuid
  rating     Int
  comment    String?
  isFlagged  Boolean  @default(false) @map("is_flagged")
  isVisible  Boolean  @default(true) @map("is_visible")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  contract Contract @relation(fields: [contractId], references: [id])
  reviewer User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@unique([contractId, reviewerId])
  @@map("reviews")
