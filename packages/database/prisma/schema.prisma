enum PostType {
  discussion
  question
  tip
  achievement
  event
  gig_posted
  gig_completed
  review_received
}

model CommunityPost {
  id        String   @id @default(uuid()) @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  type      PostType @default(discussion)
  content   String
  images    String[] @default([])
  tags      String[] @default([])
  gigId     String?  @map("gig_id") @db.Uuid
  isPinned  Boolean  @default(false) @map("is_pinned")
  isDeleted Boolean  @default(false) @map("is_deleted")
  likeCount Int      @default(0) @map("like_count")
  commentCount Int   @default(0) @map("comment_count")
  viewCount Int      @default(0) @map("view_count")
  editedAt DateTime? @map("edited_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  author   User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  gig      Gig?               @relation(fields: [gigId], references: [id], onDelete: SetNull)
  comments CommunityComment[]
  likes    CommunityLike[]
  savedBy  SavedPost[]
  views    CommunityPostView[]

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@index([type])
  @@index([gigId])
  @@map("community_posts")
}

model CommunityComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  content   String
  isDeleted Boolean  @default(false) @map("is_deleted")
  likeCount Int      @default(0) @map("like_count")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  post     CommunityPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author   User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   CommunityComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  CommunityComment[] @relation("CommentReplies")
  likes    CommunityLike[]

  @@index([postId, createdAt])
  @@index([authorId])
  @@map("community_comments")
}

model CommunityLike {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String?  @map("post_id") @db.Uuid
  commentId String?  @map("comment_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    CommunityPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@map("community_likes")
}

// ============================================================
// BLOCKED USERS 
// ============================================================

model BlockedUser {
  id        String   @id @default(uuid()) @db.Uuid
  blockerId String   @map("blocker_id") @db.Uuid
  blockedId String   @map("blocked_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  blocker User @relation("Blocking", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocked_users")
}

model UserFollow {
  id          String   @id @default(uuid()) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("user_follows")
}

model SavedPost {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@map("saved_posts")
}

model CommunityPostView {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@map("community_post_views")
}
