model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  body      String?
  data      Json     @default("{}")
  isRead    Boolean  @default(false) @map("is_read")
  channel   String   @default("in_app") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// ============================================================
// DISPUTES
// ============================================================

model Dispute {
  id               String        @id @default(uuid()) @db.Uuid
  contractId       String        @map("contract_id") @db.Uuid
  milestoneId      String?       @map("milestone_id") @db.Uuid
  serviceOrderId   String?       @map("service_order_id") @db.Uuid
  raisedById       String        @map("raised_by") @db.Uuid
  reason           String
  description      String?
  desiredResolution String?      @map("desired_resolution") @db.VarChar(50)
  evidence         Json          @default("[]")
  status           DisputeStatus @default(open)
  // Response from the other party
  responseNote     String?       @map("response_note")
  responseEvidence Json          @default("[]") @map("response_evidence")
  respondedAt      DateTime?     @map("responded_at") @db.Timestamptz
  responseDeadline DateTime?     @map("response_deadline") @db.Timestamptz
  // Resolution details
  adminNotes       String?       @map("admin_notes")
  splitPercentage  Int?          @map("split_percentage")
  refundAmount     Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  releaseAmount    Decimal?      @map("release_amount") @db.Decimal(10, 2)
  resolvedById     String?       @map("resolved_by") @db.Uuid
  resolvedAt       DateTime?     @map("resolved_at") @db.Timestamptz
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  contract     Contract      @relation(fields: [contractId], references: [id])
  milestone    Milestone?    @relation(fields: [milestoneId], references: [id])
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  raisedBy     User          @relation("DisputesRaised", fields: [raisedById], references: [id])
  resolvedBy   User?         @relation("DisputesResolved", fields: [resolvedById], references: [id])

  @@index([contractId])
  @@index([milestoneId])
  @@index([status])
  @@map("disputes")
}

